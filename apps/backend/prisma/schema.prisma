generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(uuid()) @db.Uuid
  nickname         String?          @db.VarChar(64)
  avatarUrl        String?          @map("avatar_url")
  status           String           @default("active") @db.VarChar(24)
  lastLoginAt      DateTime?        @map("last_login_at") @db.Timestamptz(6)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?        @map("deleted_at") @db.Timestamptz(6)
  wechatIdentities WechatIdentity[]
  categories       Category[]
  transactions     Transaction[]
  monthlySummaries MonthlySummary[]
  preferences      UserPreference?
  sessions         UserSession[]

  @@map("users")
}

model WechatIdentity {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  openidHash  String    @map("openid_hash") @db.VarChar(128)
  unionidHash String?   @map("unionid_hash") @db.VarChar(128)
  appid       String    @db.VarChar(64)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  user        User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([openidHash, appid], map: "uk_wechat_identities_openid_appid")
  @@map("wechat_identities")
}

model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  deviceId         String?   @map("device_id") @db.VarChar(128)
  platform         String    @default("wechat_mp") @db.VarChar(32)
  refreshTokenHash String?   @map("refresh_token_hash") @db.VarChar(128)
  status           String    @default("active") @db.VarChar(24)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  user             User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("user_sessions")
}

model Category {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String?       @map("user_id") @db.Uuid
  type         String        @db.VarChar(16)
  name         String        @db.VarChar(32)
  icon         String?       @db.VarChar(64)
  color        String?       @db.VarChar(32)
  sortOrder    Int           @default(0) @map("sort_order")
  isSystem     Boolean       @default(false) @map("is_system")
  status       String        @default("active") @db.VarChar(24)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?     @map("deleted_at") @db.Timestamptz(6)
  user         User?         @relation(fields: [userId], references: [id], onDelete: Restrict)
  transactions Transaction[]

  @@map("categories")
}

model Transaction {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  categoryId    String    @map("category_id") @db.Uuid
  type          String    @db.VarChar(16)
  amountCent    Int       @map("amount_cent")
  currency      String    @default("CNY") @db.Char(3)
  occurredAt    DateTime  @map("occurred_at") @db.Timestamptz(6)
  occurredDate  DateTime  @map("occurred_date") @db.Date
  occurredMonth String    @map("occurred_month") @db.Char(7)
  remark        String?   @db.VarChar(100)
  source        String    @default("manual") @db.VarChar(32)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  user          User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  category      Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([userId, occurredAt(sort: Desc)], map: "idx_transactions_user_occurred_at")
  @@index([userId, occurredMonth], map: "idx_transactions_user_month")
  @@index([userId, categoryId, occurredMonth], map: "idx_transactions_user_category_month")
  @@map("transactions")
}

model MonthlySummary {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  month            String   @db.Char(7)
  currency         String   @default("CNY") @db.Char(3)
  incomeCent       BigInt   @default(0) @map("income_cent")
  expenseCent      BigInt   @default(0) @map("expense_cent")
  netCent          BigInt   @default(0) @map("net_cent")
  transactionCount Int      @default(0) @map("transaction_count")
  calculatedAt     DateTime @default(now()) @map("calculated_at") @db.Timestamptz(6)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([userId, month, currency], map: "uk_monthly_summaries_user_month_currency")
  @@map("monthly_summaries")
}

model UserPreference {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  theme        String   @default("light") @db.VarChar(32)
  baseCurrency String   @default("CNY") @map("base_currency") @db.Char(3)
  locale       String   @default("zh-CN") @db.VarChar(16)
  timezone     String   @default("Asia/Shanghai") @db.VarChar(64)
  settings     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("user_preferences")
}
